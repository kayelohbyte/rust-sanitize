[1.415, "o", "\u001b[2m# No secrets file, no flags — built-in patterns just work\u001b[0m\r\n"]
[0.717, "o", "\u001b[1;32m$\u001b[0m sanitize server.log\r\n"]
[0.727, "o", "  secrets:  /tmp/sanitize-demo-work/home/.config/sanitize/secrets.yaml  [config]\r\n\r\n"]
[0.014, "o", "\r| Scanning server.log"]
[0.001, "o", "\r/ Scanning server.log: 469 B / 469 B (100%)"]
[0.011, "o", "\rdone: Scanning server.log                  \r\nRedacted: 1 aws_access_key_id, 1 credential_url, 1 email, 1 github_token, 1 ipv4, 1 url, 1 uuid\r\n"]
[0.001, "o", "\r\n"]
[1.409, "o", "\u001b[2m# Every secret is gone; structure and timestamps stay intact\u001b[0m\r\n"]
