[0.024, "o", "\u001b[2m# A real-looking app log — emails, IPs, AWS / GitHub / Stripe keys, a DB URL\u001b[0m\r\n"]
[0.712, "o", "\u001b[1;32m$\u001b[0m cat server.log\r\n"]
